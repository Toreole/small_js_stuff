{
    "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
    "spaces": 2,
    "generator-cli": {
        "version": "6.2.1",
        "generators": {
            "exampleApp": {
                "generatorName": "javascript",
                "output": "#{cwd}/api",
                "inputSpec": "../backend/api/openapi.yaml",
                "additionalProperties": {
                    "usePromises": true,
                    "sourceFolder": null
                }
            }
        }
    }
}